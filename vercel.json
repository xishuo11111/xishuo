{
    "version":  2,
    "builds":  [
                   {
                       "src":  "api/index.js",
                       "use":  "@vercel/node"
                   }
               ],
    "routes":  [
                   {
                       "src":  "/api/(.*)",
                       "dest":  "api/index.js"
                   },
                   {
                       "src":  "/(.*)",
                       "dest":  "public/$1"
                   }
               ],
    "env":  {
                "DEEPSEEK_API_KEY":  "@deepseek_api_key"
            },
    "name":  "xishuo-resume"
}
